          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"oecd_economic_data\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"economic_indicator\")\n  |> filter(fn: (r) => r[\"country_code\"] == \"SVN\")\n  |> filter(fn: (r) => r[\"indicator_code\"] == \"NY.GDP.MKTP.CD\")\n  |> filter(fn: (r) => r[\"_field\"] == \"value\")\n  |> aggregateWindow(every: 1y, fn: last, createEmpty: false)\n  |> yield(name: \"last\")"
        }
      ]
    },
